#ifndef TURBO_APPREG_RH
#define TURBO_APPREG_RH

// Minimalna definicja na RCOMP, gdy AppRegistry.h z SDK nie jest znajdowany.
// Zgodna z typowym APP_REGISTRATION_INFO (S60 3rd).
STRUCT APP_REGISTRATION_INFO
{
LTEXT app_file;
